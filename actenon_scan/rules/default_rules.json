{
  "version": "2",
  "sinks": [
    {
      "id": "PAY-STRIPE-REFUND",
      "category": "payments",
      "severity": "high",
      "description": "Stripe refund/payout/charge call in agent tool",
      "match": {"type": "attr_call", "module_patterns": ["stripe", "stripe.Refund", "stripe.Charge", "stripe.Payout", "stripe.Transfer"], "func_patterns": ["refund", "create", "capture", "charge", "payout", "transfer"]}
    },
    {
      "id": "PAY-GENERIC-REFUND",
      "category": "payments",
      "severity": "high",
      "description": "Generic payment refund/charge/payout call",
      "match": {"type": "name_call", "func_patterns": ["refund", "charge", "capture", "payout", "transfer", "create_charge", "create_refund", "issue_refund", "process_refund"]}
    },
    {
      "id": "PAY-BRAINTREE",
      "category": "payments",
      "severity": "high",
      "description": "Braintree/Adyen/PayPal payment call",
      "match": {"type": "attr_call", "module_patterns": ["braintree", "adyen", "paypal"], "func_patterns": ["refund", "sale", "capture", "void"]}
    },
    {
      "id": "DATA-DELETE-SQL",
      "category": "data_destruction",
      "severity": "high",
      "description": "Dangerous SQL DELETE/DROP string literal passed to execute/cursor",
      "match": {"type": "sql_execute_pattern", "patterns": ["\\bDELETE\\s+FROM\\b", "\\bDROP\\s+(TABLE|DATABASE)\\b"]}
    },
    {
      "id": "DATA-DELETE-SQL-RAW",
      "category": "data_destruction",
      "severity": "high",
      "description": "Dangerous SQL DELETE/DROP in f-string or string concat passed to execute/cursor",
      "match": {"type": "sql_fstring_pattern", "patterns": ["\\bDELETE\\s+FROM\\b", "\\bDROP\\s+(TABLE|DATABASE)\\b"]}
    },
    {
      "id": "DATA-DELETE-FILE",
      "category": "data_destruction",
      "severity": "high",
      "description": "File/directory deletion call (bare function name)",
      "match": {"type": "name_call", "func_patterns": ["delete", "destroy", "drop", "remove", "unlink", "rmtree"]}
    },
    {
      "id": "DATA-DELETE-OS",
      "category": "data_destruction",
      "severity": "high",
      "description": "File/directory deletion via os/shutil/pathlib module calls",
      "match": {"type": "attr_call", "module_patterns": ["os", "shutil", "pathlib", "Path"], "func_patterns": ["remove", "unlink", "rmtree", "rmdir", "removedirs"]}
    },
    {
      "id": "DATA-DELETE-OBJ",
      "category": "data_destruction",
      "severity": "high",
      "description": "Object deletion via cloud SDK",
      "match": {"type": "attr_call", "module_patterns": ["boto3", "s3", "dynamodb"], "func_patterns": ["delete_object", "delete_bucket", "delete_item", "delete_table"]}
    },
    {
      "id": "DEPLOY-SUBPROCESS",
      "category": "deployment",
      "severity": "high",
      "description": "Deployment command via subprocess/os.system",
      "match": {"type": "subprocess_deploy"}
    },
    {
      "id": "ACCESS-CONTROL-MUTATE",
      "category": "access_control",
      "severity": "high",
      "description": "Permission/access grant call",
      "match": {"type": "name_call", "func_patterns": ["put_user_policy", "attach_role_policy", "add_user_to_group", "create_access_key", "set_iam_policy", "put_bucket_policy", "put_role_policy", "create_policy", "attach_user_policy"]}
    },
    {
      "id": "COMMUNICATION-SEND",
      "category": "communication",
      "severity": "medium",
      "description": "Message/email send on behalf of user",
      "match": {"type": "attr_call", "module_patterns": ["smtplib", "email", "twilio", "slack", "webhook"], "func_patterns": ["sendmail", "send_message", "create", "postMessage", "post_message"]}
    },
    {
      "id": "COMMUNICATION-SEND-NAME",
      "category": "communication",
      "severity": "medium",
      "description": "Bare sendmail/send_message call",
      "match": {"type": "name_call", "func_patterns": ["sendmail", "send_message", "chat_postMessage", "chat_postMessage"]}
    }
  ],
  "guards": [
    {"patterns": ["verify", "verify_proof", "require_proof", "check_permission", "authorize", "require_approval", "assert_authorized", "has_permission", "check_idempotency", "seen_before", "replay_guard", "require_authorization", "validate_authorization"]},
    {"patterns": ["actenon_verify", "actenon_check", "actenon_require", "permit_check", "permit_authorize", "permit_validate", "kernel_verify"]}
  ],
  "reachability": {
    "tool_decorators": ["tool", "mcp.tool", "server.tool", "function_tool", "langchain_tool", "structured_tool", "call_tool"],
    "tool_wrappers": ["Tool.from_function", "FunctionTool.from_defaults", "StructuredTool.from_function", "tool"],
    "tool_base_classes": ["BaseTool", "AgentTool", "MCPTool"],
    "tool_methods": ["_run", "_arun", "_execute"],
    "agent_frameworks": ["langchain", "llama_index", "mcp", "openai", "autogen", "crewai"]
  }
}
