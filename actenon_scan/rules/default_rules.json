      "id": "DATABASE-MUTATE",
      "category": "database_mutation",
      "severity": "high",
      "cwe": "CWE-862",
      "owasp": "LLM06",
      "description": "Raw SQL INSERT/UPDATE/DELETE via execute/cursor",
      "match": {
        "type": "sql_execute_pattern",
