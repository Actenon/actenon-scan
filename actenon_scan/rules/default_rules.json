{
  "version": "3",
  "sinks": [
    {
      "id": "PAY-STRIPE-REFUND",
      "category": "payments",
      "severity": "high",
      "cwe": "CWE-862",
      "owasp": "LLM06",
      "description": "Stripe refund/payout/charge call in agent tool",
      "match": {
        "type": "attr_call",
        "module_patterns": [
          "stripe",
          "stripe.Refund",
          "stripe.Charge",
          "stripe.Payout",
          "stripe.Transfer"
        ],
        "func_patterns": [
          "refund",
          "create",
          "capture",
          "charge",
          "payout",
          "transfer"
        ]
      }
    },
    {
      "id": "PAY-GENERIC-REFUND",
      "category": "payments",
      "severity": "high",
      "cwe": "CWE-862",
      "owasp": "LLM06",
      "description": "Generic payment refund/charge/payout call",
      "match": {
        "type": "name_call",
        "func_patterns": [
          "refund",
          "charge",
          "capture",
          "payout",
          "transfer",
          "create_charge",
          "create_refund",
          "issue_refund",
          "process_refund"
        ]
      }
    },
    {
      "id": "PAY-BRAINTREE",
      "category": "payments",
      "severity": "high",
      "cwe": "CWE-862",
      "owasp": "LLM06",
      "description": "Braintree/Adyen/PayPal payment call",
      "match": {
        "type": "attr_call",
        "module_patterns": [
          "braintree",
          "adyen",
          "paypal"
        ],
        "func_patterns": [
          "refund",
          "sale",
          "capture",
          "void"
        ]
      }
    },
    {
      "id": "DATA-DELETE-SQL",
      "category": "data_destruction",
      "severity": "high",
      "cwe": "CWE-862",
      "owasp": "LLM06",
      "description": "Dangerous SQL DELETE/DROP string literal passed to execute/cursor",
      "match": {
        "type": "sql_execute_pattern",
        "patterns": [
          "\\bDELETE\\s+FROM\\b",
          "\\bDROP\\s+(TABLE|DATABASE)\\b"
        ]
      }
    },
    {
      "id": "DATA-DELETE-SQL-RAW",
      "category": "data_destruction",
      "severity": "high",
      "cwe": "CWE-862",
      "owasp": "LLM06",
      "description": "Dangerous SQL DELETE/DROP assigned to query/sql/statement variable",
      "match": {
        "type": "string_pattern",
        "patterns": [
          "\\bDELETE\\s+FROM\\b",
          "\\bDROP\\s+(TABLE|DATABASE)\\b"
        ]
      }
    },
    {
      "id": "DATA-DELETE-FILE",
      "category": "data_destruction",
      "severity": "high",
      "cwe": "CWE-862",
      "owasp": "LLM06",
      "description": "File/directory deletion call (bare function name)",
      "match": {
        "type": "name_call",
        "func_patterns": [
          "delete",
          "destroy",
          "drop",
          "remove",
          "unlink",
          "rmtree"
        ]
      }
    },
